// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "diff_view_style": "unified",
  "autosave": "off",
  "base_keymap": "VSCode",
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
  },
  "git_panel": {
    "dock": "left",
  },
  "terminal": {
    "flexible": true,
    "toolbar": {
      "breadcrumbs": false,
    },
    "copy_on_select": true,
    "dock": "bottom",
  },
  "cursor_shape": "bar",
  "cursor_blink": false,
  "project_panel": {
    "bold_folder_labels": true,
    "dock": "right",
  },
  "ui_font_family": "Ioskeley Mono",
  "which_key": {
    "delay_ms": 100,
    "enabled": true,
  },
  "vim": {
    "cursor_shape": {
      "visual": "underline",
    },
    "toggle_relative_line_numbers": false,
  },
  "expand_excerpt_lines": 5,
  "disable_ai": true,
  "relative_line_numbers": "disabled",
  "buffer_line_height": "standard",
  "buffer_font_family": "Ioskeley Mono",
  "icon_theme": {
    "mode": "dark",
    "light": "JetBrains Icons Dark",
    "dark": "JetBrains Icons Dark",
  },
  "telemetry": {
    "metrics": false,
  },
  "ui_font_size": 16,
  "buffer_font_size": 15.0,
  "theme": {
    "mode": "dark",
    "light": "Lauds",
    "dark": "Compline",
  },
  "helix_mode": true,
}
